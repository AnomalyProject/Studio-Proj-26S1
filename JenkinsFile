def branchMap = [
    'develop': "internal_testing",
    'network': "network_testing",
    'main'   : "default"
]

def steamBranch = "unknown"
def commitMsg = "unknown"

pipeline {
    agent any

    parameters {
        choice(name: 'BUILD_BRANCH', choices: ['develop', 'main', 'network'], description: 'Select the Git branch to build and deploy')
        string(name: 'REPO_LINK', defaultValue: 'https://github.com/thanostham/Studio-Proj-26S1.git', description: 'Source code URL')
    }

    environment {
        UNITY_PATH = '"C:\\Program Files\\Unity\\Hub\\Editor\\6000.3.10f1\\Editor\\Unity.exe"'
        CREDS = credentials('MY_SECRET_ID') 
        ANOMALY_DISCORD_WEBHOOK_URL = credentials('PROJECT_ANOMALY_DISCORD_WEBHOOK_BUILD_RESULT')
        UNITY_LOG_PATH = "${env.WORKSPACE}\\unity_build.log"
    }

    stages {

        stage('Checkout') {
            steps {
                cleanWs()
                git branch: params.BUILD_BRANCH, url: params.REPO_LINK
                script{
                    commitMsg = bat(script: "git log -1 --pretty=%s", returnStdout: true).trim().split('\n').last()
                }
            }
        }

        stage('Unity Build') {
            steps {
                bat "${UNITY_PATH} -batchmode -nographics -quit -projectPath \"%cd%\" -executeMethod BuildScript.PerformBuild -logFile \"${UNITY_LOG_PATH}\""
                sleep time: 10, unit: 'SECONDS'
            }
        }

        stage('Verify Build') {
            steps {
                script {
                    def logFile = readFile(file: UNITY_LOG_PATH)
                    if (logFile.contains('Build Finished, Result: Failure')) {
                        error 'Unity build reported a failure in the logs.'
                    }
                }
            }
        }

        stage('Deploy to Steam') {
            steps {
                script {
                    steamBranch = branchMap.get(params.BUILD_BRANCH, "internal_testing")
            
                    def contentRoot = "${WORKSPACE}\\Builds"
                    def outputRoot = "${WORKSPACE}\\SteamOutput"
                    def vdfPath = "${WORKSPACE}\\BuildScripts\\app_build.vdf"

                    bat "if not exist Builds mkdir Builds"
                    bat "if not exist SteamOutput mkdir SteamOutput"

                    def depotVdfPath = "${WORKSPACE}\\BuildScripts\\depot_build_4383781.vdf"

                    echo "Butler Jeeves: Customizing the VDF for this specific workspace..."
                    
                    bat """powershell -Command "(Get-Content '${vdfPath}') -replace 'STEAM_BRANCH_PLACEHOLDER','${steamBranch}' -replace 'CONTENT_ROOT_PLACEHOLDER','${contentRoot}' -replace 'OUTPUT_ROOT_PLACEHOLDER','${outputRoot}' | Set-Content '${vdfPath}'" """
                    bat """powershell -Command "(Get-Content '${depotVdfPath}') -replace 'CONTENT_ROOT_PLACEHOLDER','${contentRoot}' -replace 'OUTPUT_ROOT_PLACEHOLDER','${outputRoot}' | Set-Content '${depotVdfPath}'" """

                    bat "\"C:\\Tools\\steamcmd\\steamcmd.exe\" +login %CREDS_USR% %CREDS_PSW% +run_app_build \"${vdfPath}\" +quit"
                }
            }
        }
    }

    post {
        success {
            script {
                discordSend title: "✅ Build Success: ${params.BUILD_BRANCH} (#${env.BUILD_NUMBER})",
                    description: "Splendid news Sir, the build and the Deployment to Steam (${params.BUILD_BRANCH}) were successful.\n**Commit:** ${commitMsg}\n**Steam Depo:** ${steamBranch}",
                    link: env.BUILD_URL,
                    result: 'SUCCESS', //investigate why it does not print steam depo...
                    webhookURL: "${env.ANOMALY_DISCORD_WEBHOOK_URL}"
            }
        }

        aborted {
            script {
                discordSend title: "⚪ Build Aborted: ${params.BUILD_BRANCH} (#${env.BUILD_NUMBER})",
                    description: "Sir, the build was aborted, and maybe i should have been too.\n This is a manual operation so no commit descreption will be provided.",
                    link: env.BUILD_URL,
                    result: 'ABORTED',
                    webhookURL: "${env.ANOMALY_DISCORD_WEBHOOK_URL}"
            }
        }

        failure {
            script {
                discordSend title: "❌ Build Failed: ${params.BUILD_BRANCH} (#${env.BUILD_NUMBER})",
                    description: "Most unfortunate news Sir, the build for (${params.BUILD_BRANCH}) has Failed.\n**Commit:** ${commitMsg}\n**Steam Depo:** ${steamBranch}",
                    link: env.BUILD_URL,
                    result: 'FAILURE',
                    webhookURL: "${env.ANOMALY_DISCORD_WEBHOOK_URL}"
            }
        }
    }
}