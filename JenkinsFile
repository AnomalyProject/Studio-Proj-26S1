pipeline{
    agent any

    parameters{
        string(name: 'PROJECT_ANOMALY_GIT_BRANCH', defaultValue: 'main', description: 'Git Branch that pipeline builds from')
        string(name: 'PROJECT_ANOMALY_GITHUB_REPO_LINK', defaultValue: 'https://github.com/thanostham/Studio-Proj-26S1.git', description: '')
    }

    environment{
        UNITY_PATH = '"C:\\Program Files\\Unity\\Hub\\Editor\\6000.3.10f1\\Editor\\Unity.exe"'
        CREDS = credentials('MY_SECRET_ID')
        BUILD_DIR = "${env.WORKSPACE}\\Builds"
        UNITY_LOG_PATH = "${env.WORKSPACE}\\unity_build.log"
    }

    stages{
        stage('Checkout'){
            steps {
                git branch : params.PROJECT_ANOMALY_GIT_BRANCH, url: params.PROJECT_ANOMALY_GITHUB_REPO_LINK
            }
        }
        stage ('Echo smth'){
            steps{
                script{
                    echo "Hello"
                }
            }
        }
        stage('Build') {
            steps {
                bat "${UNITY_PATH} -batchmode -nographics -quit -projectPath \"%cd%\" -executeMethod BuildScript.PerformBuild -logFile \"%cd%\\unity_build.log\""
            }
        }
        stage('Check Unity Build Success'){
            steps{
                script{
                    def logFile = readFile(file: UNITY_LOG_PATH)
                    if (logFile.contains('Build Finished, Result: Failure')){
                        currentBuild.result = 'FAILURE'
                        error 'Unity build failed based on log file.'
                    }
                }
            }
        }
       stage('Deploy to Steam') {
            steps {
                 bat """
                cd /d C:\\Tools\\steamcmd
                 steamcmd +login %CREDS_USR% %CREDS_PSW% +run_app_build "${WORKSPACE}\\BuildScripts\\app_build.vdf" +quit 
                 """
            }
        }
    }
}