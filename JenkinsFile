pipeline {
    agent any

    parameters {
        choice(name: 'BUILD_BRANCH', choices: ['develop', 'main', 'thanos-jenkins-torture-ci'], description: 'Select the Git branch to build and deploy')
        string(name: 'REPO_LINK', defaultValue: 'https://github.com/thanostham/Studio-Proj-26S1.git', description: 'Source code URL')
    }

    environment {
        UNITY_PATH = '"C:\\Program Files\\Unity\\Hub\\Editor\\6000.3.10f1\\Editor\\Unity.exe"'
        CREDS = credentials('MY_SECRET_ID') 
        ANOMALY_DISCORD_WEBHOOK_URL = credentials('PROJECT_ANOMALY_DISCORD_WEBHOOK_BUILD_RESULT')
        UNITY_LOG_PATH = "${env.WORKSPACE}\\unity_build.log"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                git branch: params.BUILD_BRANCH, url: params.REPO_LINK
            }
        }

        stage('Unity Build') {
            steps {
                bat "${UNITY_PATH} -batchmode -nographics -quit -projectPath \"%cd%\" -executeMethod BuildScript.PerformBuild -logFile \"${UNITY_LOG_PATH}\""
                sleep time: 10, unit: 'SECONDS'
            }
        }

        stage('Verify Build') {
            steps {
                script {
                    def logFile = readFile(file: UNITY_LOG_PATH)
                    if (logFile.contains('Build Finished, Result: Failure')) {
                        error 'Unity build reported a failure in the logs.'
                    }
                }
            }
        }

        stage('Deploy to Steam') {
            steps {
                script {
                    def steamBranch = (params.BUILD_BRANCH == 'develop') ? "internal_testing" : "default"
            
                    def contentRoot = "${WORKSPACE}\\Builds".replace("\\", "\\\\")
                    def outputRoot = "${WORKSPACE}\\SteamOutput".replace("\\", "\\\\")
                    def vdfPath = "${WORKSPACE}\\BuildScripts\\app_build.vdf"

                    bat "if not exist Builds mkdir Builds"
                    bat "if not exist SteamOutput mkdir SteamOutput"

                    def depotVdfPath = "${WORKSPACE}\\BuildScripts\\depot_build_4383781.vdf"

                    echo "Butler Jeeves: Customizing the VDF for this specific workspace..."

                    bat """ powershell 
                        (Get-Content "${vdfPath}") `
                        -replace 'STEAM_BRANCH_PLACEHOLDER', '${steamBranch}' `
                        -replace 'CONTENT_ROOT_PLACEHOLDER', '${contentRoot}' `
                        -replace 'OUTPUT_ROOT_PLACEHOLDER', '${outputRoot}' | Set-Content "${vdfPath}"
                    """

                    bat "dir /s \"${WORKSPACE}\\Builds\""

                    bat "\"C:\\Tools\\steamcmd\\steamcmd.exe\" +login %CREDS_USR% %CREDS_PSW% +run_app_build \"${vdfPath}\" +quit"
                }
            }
        }
    }

    post {
        success {
            script {
                def commitMsg = bat(script: "git log -1 --pretty=%s", returnStdout: true).trim().split('\n').last()
                discordSend title: "✅ Build Success: ${params.BUILD_BRANCH} (#${env.BUILD_NUMBER})",
                    description: "Splendid news Sir, the build and the Deployment to Steam (${params.BUILD_BRANCH}) were successful.\n**Commit:** ${commitMsg}",
                    link: env.BUILD_URL,
                    result: 'SUCCESS',
                    webhookURL: "${env.ANOMALY_DISCORD_WEBHOOK_URL}"
            }
        }

        aborted {
            script {
                discordSend title: "⚪ Build Aborted: ${params.BUILD_BRANCH} (#${env.BUILD_NUMBER})",
                    description: "Sir, the build was aborted, and maybe i should have been too.",
                    link: env.BUILD_URL,
                    result: 'ABORTED',
                    webhookURL: "${env.ANOMALY_DISCORD_WEBHOOK_URL}"
            }
        }

        failure {
            script {
                discordSend title: "❌ Build Failed: ${params.BUILD_BRANCH} (#${env.BUILD_NUMBER})",
                    description: "Most unfortunate news Sir, the build has Failed.",
                    link: env.BUILD_URL,
                    result: 'FAILURE',
                    webhookURL: "${env.ANOMALY_DISCORD_WEBHOOK_URL}"
            }
        }
    }
}