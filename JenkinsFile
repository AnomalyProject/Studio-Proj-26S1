pipeline {
    agent any

    parameters {
        choice(name: 'BUILD_BRANCH', choices: ['develop', 'main'], description: 'Select the Git branch to build and deploy')
        string(name: 'REPO_LINK', defaultValue: 'https://github.com/thanostham/Studio-Proj-26S1.git', description: 'Source code URL')
    }

    environment {
        UNITY_PATH = '"C:\\Program Files\\Unity\\Hub\\Editor\\6000.3.10f1\\Editor\\Unity.exe"'
        CREDS = credentials('MY_SECRET_ID') 
        ANOMALY_DISCORD_WEBHOOK_URL = credentials('PROJECT_ANOMALY_DISCORD_WEBHOOK_BUILD_RESULT')
        UNITY_LOG_PATH = "${env.WORKSPACE}\\unity_build.log"
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                git branch: params.BUILD_BRANCH, url: params.REPO_LINK
            }
        }

        stage('Unity Build') {
            steps {
                bat "${UNITY_PATH} -batchmode -nographics -quit -projectPath \"%cd%\" -executeMethod BuildScript.PerformBuild -logFile \"${UNITY_LOG_PATH}\""
            }
        }

        stage('Verify Build') {
            steps {
                script {
                    def logFile = readFile(file: UNITY_LOG_PATH)
                    if (logFile.contains('Build Finished, Result: Failure')) {
                        error 'Unity build reported a failure in the logs.'
                    }
                }
            }
        }

        stage('Deploy to Steam') {
            steps {
                script {
                    def steamBeta = "default"
                    if (params.BUILD_BRANCH == 'develop') {
                        steamBeta = "internal_testing"
                    }

                    echo "Targeting Steam Branch: ${steamBeta}"

                    bat 'if exist "C:\\Tools\\steamcmd\\builder" rmdir /s /q "C:\\Tools\\steamcmd\\builder"'
                    
                    bat """
                    "C:\\Tools\\steamcmd\\steamcmd.exe" +login %CREDS_USR% %CREDS_PSW% ^
                    +run_app_build "${WORKSPACE}\\BuildScripts\\app_build.vdf" ^
                    +set_live "${steamBeta}" ^
                    +quit
                    """
                }
            }
        }
    }

    post {
        success {
            script {
                def commitMsg = bat(script: "git log -1 --pretty=%s", returnStdout: true).trim().split('\n').last()
                discordSend title: "✅ Build Success: ${params.BUILD_BRANCH} (#${env.BUILD_NUMBER})",
                    description: "Splendid news Sir, the build and the Deployment to Steam (${params.BUILD_BRANCH}) were successful.\n**Commit:** ${commitMsg}",
                    link: env.BUILD_URL,
                    result: 'SUCCESS',
                    webhookURL: "${env.ANOMALY_DISCORD_WEBHOOK_URL}"
            }
        }
        failure {
            script {
                discordSend title: "❌ Build Failed: ${params.BUILD_BRANCH} (#${env.BUILD_NUMBER})",
                    description: "Most unfortunate news Sir, the build has Failed.",
                    link: env.BUILD_URL,
                    result: 'FAILURE',
                    webhookURL: "${env.ANOMALY_DISCORD_WEBHOOK_URL}"
            }
        }
    }
}